# ==============================================================================
# .tddexempt — Modules avec couverture de tests dans une structure plate
# ==============================================================================
#
# La structure de tests des tools est PLATE par conception :
#   tools/src/asset_creator/core/subtile.py
#   → couvert par tools/tests/asset_creator/test_subtile.py
#
# tdd_check.py cherche le miroir exact (core/test_subtile.py) et ne trouve pas.
# Ces modules sont bien couverts — voir tools/tests/asset_creator/*.py (419 tests).
# ==============================================================================

# asset_creator — couvert par tools/tests/asset_creator/test_*.py
tools/src/asset_creator/core/color_ramp.py
tools/src/asset_creator/core/tile_assembler.py
tools/src/asset_creator/core/terrain.py
tools/src/asset_creator/core/subtile.py
tools/src/asset_creator/core/palette.py
tools/src/asset_creator/core/minimap.py
tools/src/asset_creator/core/texture.py
tools/src/asset_creator/core/detail_overlay.py
tools/src/asset_creator/exporters/png_exporter.py
tools/src/asset_creator/exporters/tsx_exporter.py
tools/src/asset_creator/gui/preview.py
tools/src/asset_creator/gui/pipeline.py
tools/src/asset_creator/gui/canvas.py
tools/src/asset_creator/gui/state.py
tools/src/asset_creator/preview/pygame_preview.py
tools/src/asset_creator/cli.py

# autotiles — couvert par tools/tests/autotiles/test_*.py
tools/src/autotiles/rpgmaker_blob_autotile_to_tiled.py
tools/src/autotiles/rpgmaker_autotile_to_tiled.py

