{
  "version": "0.3.0",
  "display": {
    "width": 1280,
    "height": 720,
    "fps": 60,
    "title": "RPG Tile Engine - Customizable",
    "fullscreen": true
  },
  "map": {
    "tile_size": 32,
    "map_size": 32,
    "initial_hour": 22
  },
  "colors": {
    "background": "#000000"
  },
  "debug": {
    "log_level": "INFO",
    "enabled": true
  },
  "ui": {
    "cursor_size": 32,
    "enable_failed_interaction_emote": false,
    "text_speed": 0.05
  },
  "overlay": {
    "occlusion_alpha": 130
  },
  "fonts": {
    "noble": "assets/fonts/metamorphous-regular.ttf",
    "narrative": "assets/fonts/vcr_osd_mono.ttf",
    "tech": "assets/fonts/m5x7.ttf",
    "size_noble": 18,
    "size_narrative": 14,
    "size_tech": 12
  },
  "locale": "fr"
}